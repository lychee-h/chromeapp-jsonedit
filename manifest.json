{
	"manifest_version": 3,
	"name": "JsonEditor",
	"version": "1.1.1",
	"description": "简单Json编辑器",
	"icons":
	{
		"16": "resources/icon.png",
		"48": "resources/icon.png",
		"128": "resources/icon.png"
	},
	"permissions":
	[
		"storage", "clipboardRead", "clipboardWrite", "offscreen"
	],
	"homepage_url": "https://github.com/sunzsh",
	"background": {
		"service_worker": "sw.js"
	},
	"action": {
		"default_title": "JsonEditor",
		"default_icon": {
			"16": "resources/icon.png",
			"48": "resources/icon.png",
			"128": "resources/icon.png"
		}
	},
	"omnibox": { "keyword" : "json" },
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'self'"
	}
}
